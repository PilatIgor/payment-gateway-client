{
    "name": "sharpminds/payment-gateway-client",
    "description": "PHP client for payment gateway with mTLS and HMAC",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "PilatIhor",
            "email": "pilatigor039@gmail.com"
        }
    ],
    "require": {
        "php": "^7.4",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "SharpMinds\\PaymentGatewayClient\\": "src/"
        }
    },
    "autoload-dev": {
